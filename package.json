{
  "name": "kitchen-platform",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run dev",
    "dev:discord-bot": "npm --workspace apps/discord-bot run dev",
    "build": "npm run build:shared && npm run build:api && npm run build:cli && npm run build:discord-bot && npm run build:web",
    "build:shared": "npm --workspace packages/shared-types run build",
    "build:web": "npm --workspace apps/web run build",
    "build:api": "npm --workspace apps/api run build",
    "build:cli": "npm --workspace apps/cli run build",
    "build:discord-bot": "npm --workspace apps/discord-bot run build",
    "lint": "npm run lint:web",
    "lint:web": "npm --workspace apps/web run lint",
    "test": "npm run test:web",
    "test:web": "npm --workspace apps/web run test",
    "test:smoke:ci": "npm --workspace apps/web run test:smoke:ci",
    "test:visual": "npm --workspace apps/web run test:visual",
    "ui:class-audit": "npm --workspace apps/web run ui:class-audit",
    "ops:ps": "bash scripts/ops/kitchenctl.sh ps",
    "ops:health": "bash scripts/ops/kitchenctl.sh health",
    "ops:logs": "bash scripts/ops/kitchenctl.sh logs"
  },
  "overrides": {
    "serialize-javascript": "7.0.3"
  }
}
