# ============================================
# Kitchen App - Environment Variables
# Copy this file to .env and fill in values
# ============================================

# --- Database ---
DB_PASSWORD=change_me_to_a_strong_password
DATABASE_URL=postgresql://kitchen:change_me_to_a_strong_password@postgres:5432/kitchen_app

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/auth/callback

# --- Gemini AI ---
GEMINI_API_KEY=
GEMINI_PHOTO_API_KEY=
GEMINI_PHOTO_PROJECT_ID=
GEMINI_MODEL_PHOTO_PRIMARY=gemini-2.0-flash-lite
GEMINI_MODEL_PHOTO_FALLBACK=gemini-2.5-flash-lite
GEMINI_ADVICE_API_KEY=
GEMINI_ADVICE_PROJECT_ID=
GEMINI_MODEL_ADVICE_PRIMARY=gemini-2.5-flash
GEMINI_MODEL_ADVICE_FALLBACK=gemini-2.5-flash-lite
GEMINI_ALERT_WEBHOOK_URL=
GEMINI_PHOTO_ERROR_THRESHOLD=5
GEMINI_ADVICE_ERROR_THRESHOLD=5
GEMINI_RATE_LIMIT_WINDOW_MINUTES=10

# --- Discord Bot ---
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_GUILD_ID=
DISCORD_INTERNAL_API_TOKEN=change_me_to_a_random_internal_token
MCP_AUTH_TOKEN=change_me_to_a_random_secret_token
KITCHEN_API_BASE_URL=http://api:3001

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- JWT ---
JWT_SECRET=change_me_to_a_random_64_char_string
JWT_EXPIRES_IN=7d

# --- API Server ---
API_PORT=3001
API_HOST=0.0.0.0
FRONTEND_URL=https://yourdomain.com
APP_DOMAIN=yourdomain.com

# --- Cron ---
TZ=Asia/Tokyo
WEEKLY_EMAIL_CRON="0 8 * * 1"
ENABLE_WEEKLY_EMAIL_JOB=true

# --- Operations ---
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7
LETSENCRYPT_LIVE_DIR=/etc/letsencrypt/live

# --- Node ---
NODE_ENV=production
