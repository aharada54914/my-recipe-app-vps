{
  "name": "@kitchen/discord-bot",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test:e2e:list": "playwright test --config=playwright.discord.config.ts --list",
    "test:e2e": "playwright test --config=playwright.discord.config.ts",
    "test:e2e:headed": "playwright test --config=playwright.discord.config.ts --headed"
  },
  "dependencies": {
    "@kitchen/shared-types": "*",
    "discord.js": "^14.25.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  }
}
