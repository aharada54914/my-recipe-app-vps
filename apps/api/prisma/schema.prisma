datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                 String       @id // Google sub
  email              String       @unique
  name               String?
  googleAccessToken  String?
  googleAccessTokenExpiresAt DateTime?
  googleRefreshToken String?
  preferences        Json         @default("{}")
  weeklyMenus        WeeklyMenu[]
  stocks             Stock[]
  favorites          Favorite[]
  consultationLogs   ConsultationLog[]
  discordLinks       DiscordUserLink[]
  weeklyMenuProposals WeeklyMenuProposal[]
  photoAnalysisDrafts PhotoAnalysisDraft[]
  kitchenAdviceStates KitchenAdviceState[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model Recipe {
  id                Int      @id @default(autoincrement())
  title             String
  device            String   // 'hotcook' | 'healsio' | 'manual'
  category          String
  recipeNumber      String   @unique
  baseServings      Int      @default(2)
  totalWeightG      Int      @default(0)
  totalTimeMinutes  Int      @default(30)
  ingredients       Json     // Ingredient[]
  steps             Json     // CookingStep[]
  nutritionPerServing Json?
  imageUrl          String?
  sourceUrl         String?
  isUserAdded       Boolean  @default(false)
  favorites         Favorite[]
  createdAt         DateTime @default(now())
}

model WeeklyMenu {
  id            Int      @id @default(autoincrement())
  userId        String
  weekStartDate String
  items         Json     // WeeklyMenuItem[]
  shoppingList  String?
  status        String   @default("draft")
  user          User     @relation(fields: [userId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, weekStartDate])
}

model Stock {
  id                  Int       @id @default(autoincrement())
  userId              String
  name                String
  inStock             Boolean   @default(true)
  quantity            Float?
  unit                String?
  purchasedAt         DateTime?
  expiresAt           DateTime?
  lastDetectedAt      DateTime?
  lastExpiryAlertAt   DateTime?
  detectionConfidence Float?
  user                User      @relation(fields: [userId], references: [id])

  @@unique([userId, name])
}

model Favorite {
  id       Int      @id @default(autoincrement())
  userId   String
  recipeId Int
  addedAt  DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id])
  recipe   Recipe   @relation(fields: [recipeId], references: [id])

  @@unique([userId, recipeId])
}

model ConsultationLog {
  id        Int      @id @default(autoincrement())
  userId    String
  message   String
  response  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model DiscordGuildConfig {
  id                    Int      @id @default(autoincrement())
  guildId               String   @unique
  recipeImportChannelId String?
  weeklyMenuChannelId   String?
  stockPhotoChannelId   String?
  kitchenAdviceChannelId String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model DiscordUserLink {
  id            Int      @id @default(autoincrement())
  discordUserId String   @unique
  guildId       String?
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model ConversationSession {
  id                Int                  @id @default(autoincrement())
  workflow          String
  status            String               @default("draft")
  guildId           String
  channelId         String
  threadId          String?              @unique
  discordUserId     String
  requestedServings Int?
  metadata          Json                 @default("{}")
  approvedAt        DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  turns             ConversationTurn[]
  recipeImportDraft RecipeImportDraft?
  weeklyMenuProposal WeeklyMenuProposal?
  photoAnalysisDraft PhotoAnalysisDraft?
  kitchenAdviceState KitchenAdviceState?

  @@index([guildId, workflow, createdAt])
  @@index([discordUserId, createdAt])
}

model ConversationTurn {
  id         Int                 @id @default(autoincrement())
  sessionId  Int
  actorType  String
  actorId    String
  eventType  String
  payload    Json                @default("{}")
  createdAt  DateTime            @default(now())
  session    ConversationSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId, createdAt])
}

model RecipeImportDraft {
  id               Int                 @id @default(autoincrement())
  sessionId        Int                 @unique
  sourceUrl        String
  requestedServings Int
  extractedRecipe  Json
  reviewFields     Json                @default("[]")
  status           String              @default("draft")
  createdRecipeId  Int?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  session          ConversationSession @relation(fields: [sessionId], references: [id])

  @@index([status, createdAt])
}

model WeeklyMenuProposal {
  id                   Int                 @id @default(autoincrement())
  sessionId            Int                 @unique
  userId               String
  requestedServings    Int
  weekStartDate        String
  items                Json
  weatherSummary       Json
  notes                String?
  status               String              @default("draft")
  approvedWeeklyMenuId Int?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  session              ConversationSession @relation(fields: [sessionId], references: [id])
  user                 User                @relation(fields: [userId], references: [id])

  @@index([userId, weekStartDate])
  @@index([status, createdAt])
}

model PhotoAnalysisDraft {
  id                Int                 @id @default(autoincrement())
  sessionId         Int                 @unique
  userId            String
  requestedServings Int
  imageUrl          String
  detectedIngredients Json
  candidateRecipes  Json
  status            String              @default("draft")
  selectedRecipeId  Int?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  session           ConversationSession @relation(fields: [sessionId], references: [id])
  user              User                @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model KitchenAdviceState {
  id                Int                 @id @default(autoincrement())
  sessionId         Int                 @unique
  userId            String
  requestedServings Int
  latestResponse    String
  status            String              @default("active")
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  session           ConversationSession @relation(fields: [sessionId], references: [id])
  user              User                @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([status, createdAt])
}
